# Copy this to .env and fill in your keys
PROVIDER=groq
MODEL=llama-3.3-70b-versatile

GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=

# Admin password for //admin mode (default: jarvis — change this!)
ADMIN_PASSWORD=jarvis

# Folder the coding agent may read/write. Point this at the project you want
# JARVIS to edit. Leave blank to use a safe sandbox folder inside the app.
AGENT_WORKSPACE=

# Canva Connect API access token (only needed for the Canva agent — see README).
CANVA_API_TOKEN=
